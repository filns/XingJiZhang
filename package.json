{
  "name": "xingjizhang",
  "version": "1.1.4",
  "description": "星记账 (XingJiZhang) — 轻量级个人记账桌面应用，支持 OCR 识别、微信账单导入、图表分析",
  "author": "XingJiZhang",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.xingjizhang.app",
    "productName": "星记账",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "extraResources": [
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "secrets.json",
        "to": "secrets.json"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "星记账 ${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "25.0.1",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "baidu-aip-sdk": "^4.16.0",
    "chart.js": "^4.4.0",
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.0"
  }
}
